// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url = env("DATABASE_URL")
}


model User {
  id           String   @id @default(cuid())
  name         String
  email        String   @unique
  password     String
  bio          String?
  targetExam   String?
  targetBranch String?
  createdAt    DateTime @default(now())

  savedColleges SavedCollege[]
  questions     Question[]
  answers       Answer[]
}

model College {
  id          String   @id @default(cuid())
  name        String
  location    String
  rating      Float
  fees        Int
  description String
  image       String?

  courses      Course[]
  reviews      Review[]
  savedByUsers SavedCollege[]
  predictors   CollegePredictor[]
}

model Course {
  id        String  @id @default(cuid())
  name      String
  duration  String
  fees      Int

  collegeId String
  college   College @relation(fields: [collegeId], references: [id])
}

model Review {
  id        String  @id @default(cuid())
  rating    Int
  comment   String

  collegeId String
  college   College @relation(fields: [collegeId], references: [id])
}

model SavedCollege {
  id        String @id @default(cuid())

  userId    String
  collegeId String

  user      User    @relation(fields: [userId], references: [id])
  college   College @relation(fields: [collegeId], references: [id])

  @@unique([userId, collegeId])
}

model CollegePredictor {
  id        String   @id @default(cuid())
  exam      String
  minRank   Int
  maxRank   Int
  collegeId String
  college   College  @relation(fields: [collegeId], references: [id], onDelete: Cascade)
}

model Question {
  id        String   @id @default(cuid())
  title     String
  body      String
  tags      String[]
  authorId  String
  author    User     @relation(fields: [authorId], references: [id], onDelete: Cascade)
  answers   Answer[]
  createdAt DateTime @default(now())
}

model Answer {
  id         String   @id @default(cuid())
  body       String
  authorId   String
  author     User     @relation(fields: [authorId], references: [id], onDelete: Cascade)
  questionId String
  question   Question @relation(fields: [questionId], references: [id], onDelete: Cascade)
  createdAt  DateTime @default(now())
}